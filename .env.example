# Admin Dashboard Credentials
VITE_ADMIN_USERNAME=Admin
VITE_ADMIN_PASSWORD=Admin@123

# OPTION A: Non-expiring Dropbox Authentication (Recommended)
# Instructions to generate a refresh token:
# 1. Authorize: https://www.dropbox.com/oauth2/authorize?client_id=YOUR_CLIENT_ID&token_access_type=offline&response_type=code
# 2. Exchange authorization code:
#    curl https://api.dropbox.com/oauth2/token -d code=AUTHORIZATION_CODE -d grant_type=authorization_code -u CLIENT_ID:CLIENT_SECRET
VITE_DROPBOX_REFRESH_TOKEN=your_dropbox_refresh_token_here
VITE_DROPBOX_CLIENT_ID=your_dropbox_app_key_here
VITE_DROPBOX_CLIENT_SECRET=your_dropbox_app_secret_here

# OPTION B: Short-lived Access Token Fallback (Expires in 4 hours)
VITE_DROPBOX_TOKEN=your_dropbox_access_token_here
